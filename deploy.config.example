#
# 使用说明：
# 1. 复制此文件为 deploy.config
# 2. 填写实际的配置信息
# 3. 不要将 deploy.config 提交到 Git

# Git 仓库配置
GIT_REPO_URL="github.com:645057072/ai_softomanger.git"
GIT_BRANCH="master"

# 服务器配置
SERVER_IP="47.93.44.247"
SERVER_USER="root"
SERVER_PORT="22"
# 说明：请使用 SSH 私钥免密登录（在服务器上配置 authorized_keys）

# 部署路径
REMOTE_PATH="/opt/ai_softomanger"

# 服务配置
SERVICE_PORT="80"
