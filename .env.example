# 复制为 .env 后由 docker compose 读取（勿将 .env 提交到 Git）
# 生产环境须使用强密码；root 与业务用户密码仅出现在本文件，不写进 docker-compose.yml。

# MySQL root（必填）
MYSQL_ROOT_PASSWORD=请改为强密码

# 业务库用户（与 MYSQL_USER 对应，必填）
MYSQL_PASSWORD=请改为强密码
MYSQL_USER=exam_user
MYSQL_DATABASE=exam_system

# 宿主机上直接跑 Python 时用 127.0.0.1；后端容器内 MYSQL_HOST 由 compose 写死为 db（服务名）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# 本地连 Docker 内 MySQL 时的连接串（用户名/密码须与上面一致；密码含特殊字符时请做 URL 编码）
FLASK_CONFIG=development
DATABASE_URL=mysql+pymysql://exam_user:请改为与MYSQL_PASSWORD一致@127.0.0.1:3306/exam_system?charset=utf8mb4

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# 若历史脚本使用 JWT_SECRET，可与 JWT_SECRET_KEY 二选一（进入容器后由 config 读取）
# JWT_SECRET=
